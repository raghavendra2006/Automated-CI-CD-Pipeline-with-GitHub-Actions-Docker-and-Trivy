# Trivy Vulnerability Ignore File
# ================================
# These CVEs are in npm's internal bundled dependencies (/usr/local/lib/node_modules/npm/*)
# shipped with the Node.js 18 Alpine base image. They are NOT in our application code
# and cannot be fixed without upgrading the entire Node.js major version.
# Risk accepted: These packages are only used by npm itself during build steps,
# not by our production application runtime.

# brace-expansion - DoS via exponential-time complexity (npm internal)
CVE-2026-13149

# cross-spawn - ReDoS vulnerability (npm internal)
CVE-2024-21538

# glob - Command injection via malicious filenames (npm internal)
CVE-2025-64756

# minimatch - DoS via crafted glob patterns (npm internal)
CVE-2026-26996
CVE-2026-27903
CVE-2026-27904

# sigstore - Improper certificate validation (npm internal)
CVE-2025-67625

# tar - Various path traversal and extraction vulnerabilities (npm internal)
CVE-2024-28863
CVE-2025-22893
